{{ 'store-locator.css' | asset_url | stylesheet_tag }}

<div
  id="simple-store-locator-{{ block.id }}"
  class="simple-store-locator"
  data-handle="{{ block.settings.widget_handle | default: 'default' }}"
  data-proxy-base="{{ shop.url }}/apps/store-locator"
  style="--ssl-height: {{ block.settings.height | default: 540 }}px;"
></div>

<script src="{{ 'store-locator.js' | asset_url }}" defer></script>

{% schema %}
{
  "name": "Store Locator",
  "target": "section",
  "settings": [
    { "type": "text", "id": "widget_handle", "label": "Widget handle", "default": "default" },
    { "type": "number", "id": "initial_zoom", "label": "Initial zoom", "default": 10 },
    { "type": "number", "id": "height", "label": "Map height (px)", "default": 540 },
    { "type": "text", "id": "search_placeholder", "label": "Search placeholder", "default": "Search city or ZIP" },
    { "type": "text", "id": "search_label", "label": "Search button label", "default": "Search" }
  ]
}
{% endschema %}
