{
  "name": "simple-store-locator",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "shopify app dev",
    "dev:rr": "react-router dev",
    "build": "react-router build && node ./scripts/build-worker.mjs && node ./scripts/build-extension.mjs",
    "start": "wrangler dev",
    "deploy": "npm run build && wrangler deploy",
    "typecheck": "react-router typegen && tsc --noEmit",
    "lint": "eslint .",
    "test": "vitest run",
    "test:watch": "vitest",
    "db:generate": "drizzle-kit generate",
    "db:migrate:local": "wrangler d1 migrations apply DB --local",
    "db:migrate:remote": "wrangler d1 migrations apply DB --remote",
    "db:studio": "drizzle-kit studio",
    "shopify": "shopify",
    "shopify:app": "shopify app",
    "shopify:config:link": "shopify app config link",
    "shopify:generate:extension": "shopify app generate extension",
    "shopify:deploy": "shopify app deploy"
  },
  "dependencies": {
    "@cloudflare/vite-plugin": "^1.42.4",
    "@react-router/cloudflare": "^7.18.1",
    "@shopify/app-bridge-react": "^4.2.11",
    "@shopify/polaris": "^13.9.5",
    "@shopify/shopify-api": "^13.1.0",
    "@shopify/shopify-app-react-router": "^1.2.1",
    "@shopify/shopify-app-session-storage": "^5.0.0",
    "drizzle-orm": "^0.45.2",
    "isbot": "^5.1.38",
    "leaflet": "^1.9.4",
    "papaparse": "^5.5.3",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-leaflet": "^4.2.1",
    "react-router": "^7.18.1",
    "xlsx": "https://cdn.sheetjs.com/xlsx-0.20.3/xlsx-0.20.3.tgz",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20260415.0",
    "@eslint/js": "^9.37.0",
    "@react-router/dev": "^7.18.1",
    "@shopify/cli": "^3.93.2",
    "@types/better-sqlite3": "^7.6.13",
    "@types/leaflet": "^1.9.15",
    "@types/papaparse": "^5.3.15",
    "@types/react": "^18.3.17",
    "@types/react-dom": "^18.3.5",
    "@typescript-eslint/eslint-plugin": "^8.18.0",
    "@typescript-eslint/parser": "^8.18.0",
    "better-sqlite3": "^12.11.1",
    "drizzle-kit": "^0.31.10",
    "eslint": "^9.37.0",
    "eslint-plugin-react": "^7.37.2",
    "eslint-plugin-react-hooks": "^5.1.0",
    "typescript": "^5.9.3",
    "vite": "^6.4.2",
    "vite-tsconfig-paths": "^5.1.4",
    "vitest": "^2.1.8",
    "wrangler": "^4.106.0"
  },
  "engines": {
    "node": ">=20"
  }
}
